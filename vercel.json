{
  "buildCommand": "npx vite build --config vite.config.ts",
  "outputDirectory": "dist",
  "functions": {
    "artifacts/f1-intelligence/api/index.py": {
      "runtime": "python3.11",
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "artifacts/api-server/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/artifacts/f1-intelligence/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
