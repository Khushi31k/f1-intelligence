{
  "buildCommand": "pnpm install && pnpm --filter @workspace/f1-intelligence run build && cp -r artifacts/f1-intelligence/dist dist",
  "outputDirectory": "dist",
  "functions": {
    "api/index.py": {
      "runtime": "python3.11",
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "artifacts/api-server/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
